{
    "name": "fp-venture-day",
    "private": true,
    "description": "Venture Day Archives - A static site for showcasing annual venture day presentations",
    "main": "build.js",
    "scripts": {
        "build": "node build.js",
        "dev": "node build.js && python -m http.server 8000",
        "watch": "nodemon --watch contents.yaml --exec \"node build.js\"",
        "serve": "python -m http.server 8000"
    },
    "keywords": [
        "venture",
        "day",
        "archives",
        "static",
        "site"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "js-yaml": "^4.1.0"
    },
    "devDependencies": {
        "nodemon": "^3.0.1"
    }
}
